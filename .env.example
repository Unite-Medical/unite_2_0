# ──────────────────────────────────────────────────────────────────────────
# Unite Medical 2.0 — environment template
#
# Copy to `.env` (local) and/or set these in Vercel → Project → Settings →
# Environment Variables (production). The app is built to "flip live on keys":
# every integration runs a deterministic STUB until its vars are present, then
# the real upstream is called through the serverless proxy (api/proxy/*).
#
# Check live status any time at /admin/integrations or GET /api/health.
#
# Legend:
#   [LIVE]   server-side secret — never exposed to the browser
#   [OAUTH]  also requires a one-time consent click (see GO_LIVE.md)
#   [HOOK]   also register the webhook URL in the provider dashboard
#   [VITE_]  browser-readable; only for local dev / public values
# ──────────────────────────────────────────────────────────────────────────

# ── Persistence (Neon Postgres row-store via /api/db/sync) ──────────────────
# Already provisioned. VITE_DB_SYNC_TOKEN must equal DB_SYNC_TOKEN so the SPA
# can authenticate its write-through; without it the app runs local-only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"
DB_SYNC_TOKEN="<random-32-byte-hex>"
VITE_DB_SYNC_TOKEN="<same-as-DB_SYNC_TOKEN>"

# Optional: point the SPA at a specific proxy base (defaults to same-origin /api)
# VITE_API_BASE="https://your-deployment.vercel.app/api"

# ── AI — Anthropic / Claude (PRD-11) ────────────────────────────────────────
# Powers column mapping, translation, FDA/HTS classification, cover letters,
# CEO digest, surplus valuation, vendor outreach.
ANTHROPIC_API_KEY=                       # [LIVE]
# VITE_ANTHROPIC_API_KEY=                 # [VITE_] local Node scripts only; never ship to prod

# ── Resend — transactional email (PRD-05, PRIMARY sender) ───────────────────
# Preferred email rail: one key, domain auth, no OAuth. Powers order
# confirmations, invoices, dunning, POs, outreach, rep statements, etc.
RESEND_API_KEY=                           # [LIVE]

# ── Stripe — B2B billing + 1099 rep payouts (PRD-09) ────────────────────────
STRIPE_SECRET_KEY=                        # [LIVE]
STRIPE_WEBHOOK_SECRET=                    # [HOOK] → /api/hooks/stripe
STRIPE_PUBLISHABLE_KEY=                   # browser-safe (Stripe.js)
VITE_STRIPE_PUBLISHABLE_KEY=              # [VITE_] same value, exposed to the SPA checkout

# ── Calendly — scheduling (PRD-21, PRIMARY scheduler) ───────────────────────
CALENDLY_API_KEY=                         # [LIVE]
CALENDLY_WEBHOOK_SECRET=                  # [HOOK] → /api/hooks/calendly

# ── QuickBooks Online (PRD-02) ──────────────────────────────────────────────
QBO_CLIENT_ID=                            # [OAUTH] visit /api/auth/qbo/connect once
QBO_CLIENT_SECRET=
QBO_REALM_ID=                             # company id (shown after consent)
QBO_REFRESH_TOKEN=                        # minted by the callback; or set QBO_ACCESS_TOKEN directly
QBO_ENVIRONMENT="sandbox"                 # "production" when going live

# ── Google — Gmail inbox + Calendar mirror (PRD-05) — OPTIONAL ──────────────
# NOT required: Resend handles outbound email and Calendly handles
# scheduling. Add this only if you want inbox reading (AI triage) and/or
# events mirrored into a Google Calendar. One grant covers both.
GOOGLE_CLIENT_ID=                         # [OAUTH] visit /api/auth/google/connect once
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=                     # minted by the callback

# ── Flexport — landed cost + customs status (PRD-03) ────────────────────────
FLEXPORT_API_KEY=                         # [LIVE] OR the client-credentials pair below
# FLEXPORT_CLIENT_ID=
# FLEXPORT_CLIENT_SECRET=
FLEXPORT_WEBHOOK_SECRET=                  # [HOOK] → /api/hooks/flexport
RESTORE_WEBHOOK_SECRET=                   # [HOOK] → /api/hooks/restore (savings bridge, shared with Brad)

# ── Cin7 Core (DEAR) — WMS / inventory source of truth (PRD-04) ─────────────
CIN7_ACCOUNT_ID=                          # [LIVE]
CIN7_APPLICATION_KEY=

# ── ShipStation — shipping labels + tracking (PRD-04 / PRD-24) ──────────────
SHIPSTATION_API_KEY=                      # [LIVE]
SHIPSTATION_API_SECRET=
SHIPSTATION_WEBHOOK_SECRET=               # [HOOK] → /api/hooks/shipstation

# ── Shopify — headless commerce engine (PRD-04) ─────────────────────────────
# Dev Dashboard app (legacy custom apps deprecated Jan 2026). The proxy
# exchanges Client ID/Secret for a short-lived Admin token (client-credentials
# grant); Storefront API is browser-safe.
SHOPIFY_STORE_DOMAIN=                      # e.g. unitemedical.myshopify.com
SHOPIFY_CLIENT_ID=                         # [LIVE] Dev Dashboard app Client ID
SHOPIFY_CLIENT_SECRET=                     # [LIVE] Client Secret (also signs webhook HMACs)
SHOPIFY_ADMIN_TOKEN=                       # optional: permanent offline token to skip the grant
SHOPIFY_WEBHOOK_SECRET=                    # [HOOK] optional override if you set a distinct signing secret
SHOPIFY_API_VERSION="2026-04"              # Admin/Storefront API version
SHOPIFY_STOREFRONT_TOKEN=                  # Storefront API token (via storefrontAccessTokenCreate)
VITE_SHOPIFY_STOREFRONT_TOKEN=             # [VITE_] same value, for SPA headless calls
VITE_SHOPIFY_STORE_DOMAIN=                 # [VITE_] same as SHOPIFY_STORE_DOMAIN, for the SPA

# ── HubSpot — CRM / 1099 rep pipeline (PRD-06) ──────────────────────────────
HUBSPOT_PRIVATE_APP_TOKEN=                # [LIVE]

# ── GS1 US Data Hub — GTIN validation (PRD-07) ──────────────────────────────
GS1_API_KEY=                              # [LIVE]
GS1_ACCOUNT_ID=

# ── ImportGenius — trade intelligence / vendor discovery (PRD-15) ───────────
IMPORTGENIUS_API_KEY=                     # [LIVE]

# ── Fathom — call recordings → action items (PRD-05) ────────────────────────
FATHOM_WEBHOOK_SECRET=                    # [HOOK] → /api/hooks/fathom (webhook-only, no outbound key)

# ── Demand forecasting sidecar — Python/Prophet (PRD-12) ────────────────────
# The only integration that needs a deployed service, not just a key.
FORECAST_API_URL=                         # e.g. https://forecast.internal.unitemedical.net
FORECAST_API_TOKEN=                       # optional bearer

# ── openFDA / USITC HTS ─────────────────────────────────────────────────────
# Free, no auth required. Optional key only raises openFDA rate limits.
# OPENFDA_API_KEY=
